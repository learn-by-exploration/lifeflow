{
  "name": "lifeflow",
  "version": "0.7.2",
  "description": "Self-hosted personal task planner with 4-level hierarchy, 25+ views, and zero cloud dependencies",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "backup": "bash scripts/backup.sh",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "pretest": "bash scripts/backup.sh",
    "test": "node --test --test-force-exit tests/*.test.js"
  },
  "keywords": [
    "task-manager",
    "productivity",
    "self-hosted",
    "personal-planner",
    "sqlite",
    "express"
  ],
  "author": "Learn by Exploration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/learn-by-exploration/lifeflow.git"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
