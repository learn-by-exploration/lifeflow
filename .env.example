# LifeFlow Environment Configuration
# Copy this file to .env and adjust values as needed.
# All values shown are defaults — the app works without a .env file.

# Server
PORT=3456
NODE_ENV=development

# Database directory (where lifeflow.db lives)
DB_DIR=./

# Logging
LOG_LEVEL=info          # silent | error | warn | info | debug

# Session
SESSION_MAX_AGE_DAYS=7
SESSION_REMEMBER_DAYS=30

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Auth Rate Limiting
AUTH_LIMIT_WINDOW_MS=900000
AUTH_LIMIT_MAX=20

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Backup
BACKUP_RETAIN_COUNT=7
BACKUP_INTERVAL_HOURS=24

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# ─── Reverse Proxy ───
# Set to "true" when behind Nginx, Caddy, ALB, Cloudflare, etc.
# Required for correct client IP detection, Secure cookies, and HSTS headers.
# TRUST_PROXY=true

# ─── CORS ───
# Comma-separated list of allowed origins for cross-origin requests.
# Leave empty for same-origin only (default, most secure).
# ALLOWED_ORIGINS=https://app.example.com,https://other.example.com

# ─── Base URL ───
# Canonical URL of the application (used in shared links and emails).
# BASE_URL=https://lifeflow.example.com

# Web Push (VAPID)
# Generate keys: node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
