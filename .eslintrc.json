{
  "env": {
    "node": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "eqeqeq": ["error", "always"],
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-var": "error",
    "prefer-const": "warn",
    "no-unused-vars": ["warn", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^_"
    }],
    "no-throw-literal": "error",
    "no-implicit-globals": "error",
    "curly": ["error", "multi-line"]
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": {
        "node": true
      },
      "rules": {
        "no-unused-vars": ["warn", {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }]
      }
    }
  ]
}
